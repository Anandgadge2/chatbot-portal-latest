{
  "metadata": {
    "name": "East Bhanupratappur Forest Division Flow",
    "description": "WhatsApp Citizen Helpdesk for East Bhanupratappur Forest Division to report forest related issues.",
    "companyId": "dfo_flow",
    "version": 1,
    "isActive": true
  },
  "settings": {
    "sessionTimeout": 30,
    "errorFallbackMessage": "⚠️ I'm sorry, I didn't understand that. Please use the menu buttons or type 'menu' to restart.",
    "enableTypingIndicator": true,
    "commands": {
      "stop": {
        "keywords": ["stop", "end", "exit", "quit", "bye", "terminate", "बंद करें", "रोको"],
        "clearSession": true,
        "responses": {
          "en": "🛑 *Session Ended*\n\nThank you for using East Bhanupratappur Forest Division Helpdesk.\n\nType *Hi* anytime to start again. 🙏",
          "hi": "🛑 *सत्र समाप्त*\n\nपूर्व भानुप्रतापपुर वनमंडल हेल्पडेस्क का उपयोग करने के लिए धन्यवाद।\n\nदोबारा शुरू करने के लिए *Hi* टाइप करें। 🙏"
        }
      },
      "restart": {
        "keywords": ["restart", "restrt", "reset", "start again", "फिर से शुरू", "पुनः शुरू"],
        "clearSession": true,
        "restartFlow": true,
        "responses": {
          "en": "🔄 *Restarting...*\n\nLet's start fresh!",
          "hi": "🔄 *पुनः शुरुआत...*\n\nचलिए फिर से शुरू करते हैं!"
        }
      },
      "menu": {
        "keywords": ["menu", "main menu", "home", "मेनू", "मुख्य मेनू"],
        "clearSession": false,
        "navigateTo": "language_selection",
        "responses": {
          "en": "🏠 *Returning to Main Menu...*",
          "hi": "🏠 *मुख्य मेनू पर वापस...*"
        }
      },
      "back": {
        "keywords": ["back", "previous", "prev", "go back", "वापस", "पीछे"],
        "clearSession": false,
        "navigateToPrevious": true,
        "responses": {
          "en": "🔙 *Going back...*",
          "hi": "🔙 *वापस जा रहे हैं...*"
        }
      }
    },
    "fallback": {
      "button": {
        "maxAttempts": 3,
        "resendStepOnFallback": true,
        "messages": {
          "en": "⚠️ *Invalid selection.*\n\nPlease tap one of the buttons above to continue.\n\n_Type *menu* to go to the Main Menu or *stop* to exit._",
          "hi": "⚠️ *अमान्य चयन।*\n\nजारी रखने के लिए ऊपर दिए गए बटनों में से किसी एक पर टैप करें।\n\n_मुख्य मेनू के लिए *menu* या बाहर निकलने के लिए *stop* टाइप करें।_"
        },
        "maxAttemptsMessage": {
          "en": "❗ Too many invalid attempts. Returning to Main Menu...",
          "hi": "❗ बहुत अधिक अमान्य प्रयास। मुख्य मेनू पर वापस जा रहे हैं..."
        }
      },
      "list": {
        "maxAttempts": 3,
        "resendStepOnFallback": true,
        "messages": {
          "en": "⚠️ *Invalid selection.*\n\nPlease tap the *Select* button to open the menu and choose an option.\n\n_Type *menu* to go to the Main Menu or *stop* to exit._",
          "hi": "⚠️ *अमान्य चयन।*\n\nमेनू खोलकर विकल्प चुनने के लिए *चुनें* बटन पर टैप करें।\n\n_मुख्य मेनू के लिए *menu* या बाहर निकलने के लिए *stop* टाइप करें।_"
        },
        "maxAttemptsMessage": {
          "en": "❗ Too many invalid attempts. Returning to Main Menu...",
          "hi": "❗ बहुत अधिक अमान्य प्रयास। मुख्य मेनू पर वापस जा रहे हैं..."
        }
      },
      "input": {
        "maxAttempts": 3,
        "messages": {
          "en": "⚠️ *Invalid input.*\n\nPlease provide the required information to continue.\n\n_Type *menu* for Main Menu or *stop* to exit._",
          "hi": "⚠️ *अमान्य इनपुट।*\n\nजारी रखने के लिए आवश्यक जानकारी प्रदान करें।\n\n_मुख्य मेनू के लिए *menu* या बाहर निकलने के लिए *stop* टाइप करें।_"
        },
        "maxAttemptsMessage": {
          "en": "❗ Too many invalid attempts. Returning to Main Menu...",
          "hi": "❗ बहुत अधिक अमान्य प्रयास। मुख्य मेनू पर वापस जा रहे हैं..."
        }
      }
    }
  },
  "translations": {
    "en": {
      "welcome": "Welcome to the Official WhatsApp Helpdesk\nEast Bhanupratappur Forest Division",
      "track_not_found": "❌ *No Records Found*\n\nWe could not find any record matching that reference number.\n\nPlease double-check the number or contact support.",
      "track_found": "📌 📄 *Complaint Status*\n\n🎫 Ref No: {refNumber}\n📂 Category: {category}\n📊 Status: 📋 {status}\n👨‍💼 Assigned Officer: {assignedOfficer}\n\n📝 Details: {remarks}"
    },
    "hi": {
      "welcome": "पूर्व भानुप्रतापपुर वनमंडल\nआधिकारिक व्हाट्सएप हेल्पडेस्क में आपका स्वागत है।",
      "track_not_found": "❌ *कोई रिकॉर्ड नहीं मिला*\n\nहमें उस संदर्भ संख्या से मेल खाने वाला कोई रिकॉर्ड नहीं मिला।\n\nकृपया संख्या की दोबारा जांच करें या सहायता से संपर्क करें।",
      "track_found": "📌 📄 *शिकायत की स्थिति*\n\n🎫 संदर्भ संख्या: {refNumber}\n📂 श्रेणी: {category}\n📊 स्थिति: 📋 {status}\n👨‍💼 नियुक्त अधिकारी: {assignedOfficer}\n\n📝 विवरण: {remarks}"
    }
  },
  "nodes": [
    {
      "id": "start_node",
      "type": "start",
      "position": { "x": 0, "y": 0 },
      "data": {
        "label": "Start Trigger",
        "trigger": "start",
        "triggerType": "keyword"
      }
    },
    {
      "id": "language_selection",
      "type": "buttonMessage",
      "position": { "x": 300, "y": 0 },
      "data": {
        "label": "Language Selection",
        "messageText": "🌲 *Welcome to the Official WhatsApp Helpdesk*\n*East Bhanupratappur Forest Division*\n\nYou can use this service for:\n• Reporting Forest-related Issues\n• Tracking Complaint Status\n\n🌲 *पूर्व भानुप्रतापपुर वनमंडल*\n*आधिकारिक व्हाट्सएप हेल्पडेस्क में आपका स्वागत है।*\n\nआप इस सेवा का उपयोग कर सकते हैं:\n• वन अपराध/सूचना दर्ज करने हेतु\n• शिकायत की स्थिति देखने हेतु\n\n👇 Select Language / भाषा चुनें:",
        "buttons": [
          { "id": "lang_en", "text": "English", "type": "quick_reply" },
          { "id": "lang_hi", "text": "हिंदी", "type": "quick_reply" }
        ]
      }
    },
    {
      "id": "main_menu_en",
      "type": "listMessage",
      "position": { "x": 600, "y": -200 },
      "data": {
        "label": "Main Menu (EN)",
        "messageText": "🏛️ *Citizen Services Menu*\n\nPlease select a service:",
        "buttonText": "Select Service",
        "sections": [
          {
            "title": "Services",
            "rows": [
              { "id": "report_en", "title": "Report an Issue", "description": "Lodge a formal complaint" },
              { "id": "track_en", "title": "Complaint Status", "description": "Check complaint status" },
              { "id": "helpdesk_en", "title": "Helpdesk & Contact", "description": "Helpline and office info" },
              { "id": "about_en", "title": "About Forest Division", "description": "Learn about our mission" }
            ]
          }
        ]
      }
    },
    {
