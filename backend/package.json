{
  "name": "whatsapp-chatbot-backend",
  "version": "1.0.0",
  "description": "Multi-tenant WhatsApp chatbot platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed:superadmin": "ts-node src/scripts/seedSuperAdmin.ts",
    "seed:modules": "ts-node src/scripts/seedModules.ts",
    "sync:system": "ts-node src/scripts/syncSystem.ts",
    "cleanup:templates": "node cleanup_with_log.mjs",
    "patch:grievance-flow": "ts-node src/scripts/patchGrievanceConsentFlow.ts",
    "test": "jest",
    "export:migration": "ts-node src/scripts/exportMigrationBundle.ts"
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "multi-tenant",
    "rbac"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/moment-timezone": "^0.5.13",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "logger.js": "^0.0.1",
    "moment-timezone": "^0.6.2",
    "mongoose": "^8.21.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.1",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.28",
    "@types/nodemailer": "^6.4.21",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
